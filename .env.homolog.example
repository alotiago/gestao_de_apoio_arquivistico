# =========================================================
# Gestao de Apoio Arquivistico — VARIAVEIS DE HOMOLOGACAO
#
# Copie para .env.homolog e preencha os campos obrigatórios:
#   cp .env.homolog.example .env.homolog
#   # edite os valores marcados com CHANGE_ME
#
# SEGURANÇA:
#   - Jamais commite .env.homolog no repositório
#   - Use senhas distintas das de produção
#   - JWT_SECRET_KEY deve ter ≥ 32 caracteres
# =========================================================

# ─── Acesso público ──────────────────────────────────────
# IP ou domínio da VM de homologação (sem http:// ou /)
# Ex: 10.10.11.93:8080   ou   hml.seu-dominio.com.br
HOST_IP=CHANGE_ME_IP_OU_DOMINIO_HML

# URL completa que o browser usa para chamar a API
# Deve corresponder ao HOST_IP acima
NEXT_PUBLIC_API_URL=http://CHANGE_ME_IP_OU_DOMINIO_HML/api/v1

# ─── Nginx ───────────────────────────────────────────────
# Em VM compartilhada com produção:  127.0.0.1:8080:80
# Em VM dedicada para homolog:       80:80
NGINX_BIND=127.0.0.1:8080:80

# ─── Banco de dados ──────────────────────────────────────
POSTGRES_DB=gestao_arquivistica_hml
POSTGRES_USER=gestor_hml
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_HML_STRONG

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_HML_STRONG

# ─── MinIO ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin_hml
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_HML_STRONG

# ─── JWT (≥ 32 caracteres, base64 recomendado) ───────────
JWT_SECRET_KEY=CHANGE_ME_JWT_HML_MIN_32_CHARS_DIFFERENT_FROM_PROD

# ─── Celery / Redis DB indexes ───────────────────────────
CELERY_CONCURRENCY=1

# ─── Uvicorn ─────────────────────────────────────────────
UVICORN_WORKERS=2

# ─── CORS ────────────────────────────────────────────────
# Deve ser um JSON array válido numa única linha
CORS_ORIGINS=["http://CHANGE_ME_IP_OU_DOMINIO_HML"]

# ─── App metadata ────────────────────────────────────────
ENVIRONMENT=homolog
APP_NAME=Gestao de Apoio Arquivistico - Homologacao
