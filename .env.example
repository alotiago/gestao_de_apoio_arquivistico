# ===========================================================
# Gestão de Apoio Arquivístico — Variáveis de Ambiente
# ===========================================================
# Copie este arquivo para .env e ajuste os valores

# ---- PostgreSQL ----
DATABASE_URL=postgresql+asyncpg://gestor:gestor123@localhost:5432/gestao_arquivistica

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ---- JWT ----
JWT_SECRET_KEY=CHANGE_ME_super_secret_key_min_32_chars!!
JWT_REFRESH_SECRET_KEY=CHANGE_ME_refresh_secret_key_min_32!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ---- MinIO / S3 ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=gestao-arquivistica
S3_REGION=us-east-1

# ---- CORS ----
CORS_ORIGINS=["http://localhost:4000","http://localhost:8000"]

# ---- Upload ----
MAX_UPLOAD_SIZE_MB=50

# ---- Antivirus (ClamAV) ----
CLAMAV_ENABLED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10
CLAMAV_FAIL_OPEN=false

# ---- Observabilidade ----
ENABLE_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---- App ----
APP_NAME=Gestão de Apoio Arquivístico
DEBUG=true
LOG_LEVEL=INFO
