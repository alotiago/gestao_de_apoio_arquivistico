# ===========================================================
# Gestao de Apoio Arquivistico - Variaveis para OCI VM
# Copie para .env e ajuste os valores antes do deploy.
# ===========================================================

# ---- Public URL (importante para o frontend) ----
# Exemplo com IP:   http://140.238.xxx.xxx/api/v1
# Exemplo com DNS:  https://arquivo.exemplo.com/api/v1
NEXT_PUBLIC_API_URL=http://SEU_IP_OU_DOMINIO/api/v1

# ---- Banco (PostgreSQL) ----
POSTGRES_DB=gestao_arquivistica
POSTGRES_USER=gestor
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_STRONG

# ---- Redis / Celery ----
REDIS_PASSWORD=CHANGE_ME_REDIS_STRONG
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_STRONG@redis:6379/2
CELERY_CONCURRENCY=2

# ---- JWT ----
JWT_SECRET_KEY=CHANGE_ME_SUPER_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET_KEY=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ---- MinIO / S3 ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STRONG
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_MINIO_STRONG
S3_BUCKET=gestao-arquivistica
S3_REGION=us-east-1
S3_BUCKET_EVIDENCIAS=evidencias
S3_BUCKET_WORM=worm-logs

# ---- CORS ----
# Deve ser array JSON em uma linha
CORS_ORIGINS=["http://SEU_IP_OU_DOMINIO","https://SEU_DOMINIO"]

# ---- Upload ----
MAX_UPLOAD_SIZE_MB=50

# ---- Antivirus ----
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10
CLAMAV_FAIL_OPEN=false

# ---- Observabilidade ----
ENABLE_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

# ---- App ----
APP_NAME=Gestao de Apoio Arquivistico
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
UVICORN_WORKERS=2
